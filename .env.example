# Postgres connection string used by @vercel/postgres and the psql scripts.
# Local:  postgres://postgres:postgres@localhost:5432/gratitude
# Vercel: provided automatically when you attach a Vercel Postgres / Neon store.
POSTGRES_URL="postgres://postgres:postgres@localhost:5432/gratitude"

# Public base URL the QR codes point at (used by `pnpm card:new` to print links).
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
