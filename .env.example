# Postgres connection string used by @vercel/postgres and the psql scripts.
# Local:  postgres://postgres:postgres@localhost:5433/gratitude
# Vercel: provided automatically when you attach a Vercel Postgres / Neon store.
POSTGRES_URL="postgres://postgres:postgres@localhost:5433/gratitude"

# Public base URL the QR codes point at (used by `pnpm card:new` to print links).
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Web Push VAPID keys — generate once with: npx web-push generate-vapid-keys
# The public key is exposed to the browser; keep the private key secret.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<public key>
VAPID_PRIVATE_KEY=<private key>
VAPID_SUBJECT=mailto:you@example.com
